{
  "plansDirectory": ".claude/plans",
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(npm *)",
      "Bash(npx tsc *)",
      "Bash(notebooklm *)",
      "Bash(git *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(docker *)",
      "Bash(curl *)",
      "Bash(grep *)",
      "Bash(python3 *)",
      "Bash(rm -rf *)",
      "Bash(mkdir *)",
      "Bash(awk *)",
      "Bash(xargs *)",
      "WebFetch(domain:api.anthropic.com)",
      "mcp__MCP_DOCKER__browser_navigate",
      "mcp__MCP_DOCKER__browser_snapshot",
      "mcp__MCP_DOCKER__browser_take_screenshot",
      "mcp__MCP_DOCKER__browser_click",
      "mcp__MCP_DOCKER__browser_type",
      "mcp__MCP_DOCKER__browser_fill_form",
      "mcp__MCP_DOCKER__browser_evaluate",
      "mcp__MCP_DOCKER__browser_console_messages",
      "mcp__MCP_DOCKER__browser_network_requests",
      "mcp__MCP_DOCKER__browser_wait_for",
      "mcp__MCP_DOCKER__browser_navigate_back",
      "mcp__MCP_DOCKER__browser_close",
      "mcp__MCP_DOCKER__kubectl_generic",
      "mcp__MCP_DOCKER__find",
      "mcp__MCP_DOCKER__aggregate",
      "mcp__MCP_DOCKER__count",
      "mcp__MCP_DOCKER__list-collections",
      "mcp__MCP_DOCKER__list-databases",
      "mcp__MCP_DOCKER__fetch",
      "mcp__MCP_DOCKER__ping"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,os,subprocess,pathlib; d=json.loads(os.environ.get('CLAUDE_TOOL_INPUT','{}')); f=d.get('file_path',''); exit(0) if not f.endswith('.go') else None; subprocess.run(['gofmt','-w',f]); r=subprocess.run(['go','vet','./...'],cwd=str(pathlib.Path(f).parent),capture_output=True,text=True); print(r.stdout+r.stderr) if r.returncode!=0 else None\""
          },
          {
            "type": "command",
            "command": "python3 -c \"import json,os,subprocess,pathlib; d=json.loads(os.environ.get('CLAUDE_TOOL_INPUT','{}')); f=d.get('file_path',''); exit(0) if not f.endswith(('.ts','.tsx')) else None; pts=pathlib.Path(f).parents; p=next((pts[i] for i in range(min(10,len(pts))) if (pts[i]/'tsconfig.json').exists()),pts[0]); r=subprocess.run(['npx','tsc','--noEmit'],cwd=str(p),capture_output=True,text=True); print((r.stdout+r.stderr)[-3000:]) if r.returncode!=0 else None\""
          }
        ]
      }
    ]
  },
  "skillOverrides": {
    "golang-concurrency": "off",
    "golang-context": "off",
    "golang-data-structures": "off",
    "golang-design-patterns": "off",
    "golang-error-handling": "off",
    "golang-naming": "off",
    "golang-patterns": "off",
    "golang-performance": "off",
    "golang-popular-libraries": "off",
    "golang-project-layout": "off",
    "golang-samber-oops": "off",
    "golang-security": "off",
    "golang-swagger": "off",
    "golang-testing": "off",
    "golang-troubleshooting": "off",
    "vercel-react-best-practices": "off",
    "sequential-thinking": "off",
    "k8s-security-policies": "off",
    "k8s-yaml-validator": "off",
    "k8s-manifest-generator": "off"
  }
}
