jenkins:
  adminPassword: ""
  githubUser: ""        # must set — GitHub username or org (e.g. kittitadkp)
  githubPat: ""         # must set — GitHub → Settings → Developer tokens
  nexusUser: "admin"
  nexusPat: ""          # must set — Nexus admin password
  sonarToken: ""        # must set — SonarQube → My Account → Security
  # Repo URLs — all optional, default to https://github.com/<githubUser>/<name>.git
  githubCredsId: "github-creds"          # Jenkins credential ID for GitHub
  jenkinsRepo: ""                        # defaults to <githubUser>/jeeb-jenkins.git
  k8sRepo: ""                            # defaults to <githubUser>/jeeb.git
  backendRepo: ""                        # defaults to <githubUser>/jeeb-backend.git
  frontendRepo: ""                       # defaults to <githubUser>/jeeb-frontend.git
  learningBackendRepo: ""                # defaults to <githubUser>/learning-backend.git
  learningFrontendRepo: ""               # defaults to <githubUser>/learning-frontend.git

keycloak:
  adminUser: "admin"
  adminPassword: ""

mongodb:
  username: "jeeb"
  password: ""

nexus:
  adminPassword: ""

sonarqube:
  adminPassword: ""

grafana:
  adminPassword: ""

kong:
  # Fill after Keycloak is running — run 'k8s-manager kong-key' to update.
  keycloakPublicKey: ""

# Cluster topology — all fields are optional.
# Defaults match the jeeb Docker Desktop setup.
# Override here instead of using K8SM_* environment variables.
cluster:
  namespaces:
    dev: jeeb-dev
    infra: jeeb-infra
    obs: jeeb-obs
  releases:
    data: jeeb-data
    dev: jeeb-dev
    infra: jeeb-infra
    learning: jeeb-learning
    obs: jeeb-obs
  vault:
    pod: vault-0
    addr: http://127.0.0.1:8200
  keycloak:
    realm: jeeb
    clientId: jeeb-app
    host: keycloak.jeeb-dev.svc.cluster.local:8080
    nodePort: 30081
  kong:
    issuer: http://auth.jeeb-dev.local/realms/jeeb
    nodePort: 30088
  mongo:
    host: mongodb.jeeb-dev.svc.cluster.local:27017
    nodePort: 30017
  nodePorts:
    frontend: 30000
    backend: 30080
    jenkins: 30082
    jenkinsAgent: 30500
    nexusUI: 30083
    learningBackend: 30086
    learningFront: 30087
    sonarQube: 30090
    vault: 30091
    grafana: 30092
    prometheus: 30093
  nexus:
    registry: localhost:30050
  ingress:
    label: app.kubernetes.io/name=ingress-nginx
  rancher:
    nodePort: 30443
    hostname: rancher.jeeb-infra.local
    namespace: cattle-system
    certManagerNamespace: cert-manager
  vaultPaths:
    backend: secret/data/jeeb/backend/develop
    frontend: secret/data/jeeb/frontend/develop
    learningBackend: secret/data/jeeb/learning/backend/develop
    learningFrontend: secret/data/jeeb/learning/frontend/develop
