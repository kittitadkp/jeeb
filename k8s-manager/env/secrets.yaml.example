# env/secrets.yaml — service credentials for the jeeb cluster.
# Copy this file to env/secrets.yaml and fill every required value.
# Never commit secrets.yaml (it is gitignored).

jenkins:
  adminPassword: ""          # required
  githubUser: ""             # required — GitHub username or org (e.g. kittitadkp)
  githubPat: ""              # required — GitHub → Settings → Developer tokens (repo scope)
  nexusUser: "admin"         # almost always "admin"
  nexusPassword: ""          # required — Nexus admin password (same as nexus.adminPassword below)
  sonarToken: ""             # fill after SonarQube is up: SonarQube → My Account → Security
  githubCredsId: "github-creds"          # Jenkins credential ID for GitHub
  # Repo URLs — all optional, default to https://github.com/<githubUser>/<name>.git
  jenkinsRepo: ""                        # defaults to <githubUser>/jeeb-jenkins.git
  k8sRepo: ""                            # defaults to <githubUser>/jeeb.git
  backendRepo: ""                        # defaults to <githubUser>/jeeb-backend.git
  frontendRepo: ""                       # defaults to <githubUser>/jeeb-frontend.git
  learningBackendRepo: ""                # defaults to <githubUser>/learning-backend.git
  learningFrontendRepo: ""               # defaults to <githubUser>/learning-frontend.git

keycloak:
  adminUser: "admin"
  adminPassword: ""          # required

mongodb:
  username: "jeeb"
  password: ""               # required

nexus:
  adminPassword: ""          # required

sonarqube:
  adminPassword: ""          # required

grafana:
  adminPassword: ""          # required

kong:
  # Filled automatically by 'k8s-manager kong-key' after Keycloak is running.
  keycloakPublicKey: ""
